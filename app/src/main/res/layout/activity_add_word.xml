<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/addWords"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddWordActivity">

    <EditText
        android:id="@+id/wordInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter a word"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginTop="200dp"
        android:layout_marginEnd="32dp"
        />

    <EditText
        android:id="@+id/bookInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="What book did you find this word in?"
        app:layout_constraintTop_toBottomOf="@+id/wordInput"
        app:layout_constraintStart_toStartOf="@+id/wordInput"
        app:layout_constraintEnd_toEndOf="@+id/wordInput"
        android:layout_marginTop="16dp"
        />

    <Button
        android:id="@+id/saveWord"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Save word and view meaning"
        app:layout_constraintTop_toBottomOf="@id/bookInput"
        app:layout_constraintStart_toStartOf="@id/bookInput"
        app:layout_constraintEnd_toEndOf="@id/bookInput"
        android:layout_marginTop="24dp"
        />

    <TextView
        android:id="@+id/wordMeaning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="16sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/saveWord"
        app:layout_constraintStart_toStartOf="@id/saveWord"
        app:layout_constraintEnd_toEndOf="@id/saveWord" />

    <Button
        android:id="@+id/homeButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Home"
        app:layout_constraintTop_toBottomOf="@id/wordMeaning"
        app:layout_constraintStart_toStartOf="@id/wordMeaning"
        app:layout_constraintEnd_toEndOf="@id/wordMeaning"
        android:layout_marginTop="24dp"
        />


</androidx.constraintlayout.widget.ConstraintLayout>